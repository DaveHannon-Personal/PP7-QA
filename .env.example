# ─── ProPresenter 7 Connection ───────────────────────────────────────────────
# Default values match the official ProPresenter API docs (http://localhost:50001)
# These are used as startup fallbacks only. The Settings UI persists overrides to the DB.
PROPRESENTER_URL=http://host.docker.internal
PROPRESENTER_PORT=50001

# ─── AI (Ollama) ─────────────────────────────────────────────────────────────
# For Apple Silicon (default): Ollama runs natively on the Mac host.
# host.docker.internal resolves to the Mac host from inside Docker containers.
OLLAMA_URL=http://host.docker.internal:11434
# Recommended model — run: ollama pull llama3.2:3b
# Alternative for better reasoning: ollama pull mistral:7b
OLLAMA_MODEL=llama3.2:3b

# ─── Service Ports ───────────────────────────────────────────────────────────
FRONTEND_PORT=3000
API_PORT=8000

# ─── Container Memory Limits ─────────────────────────────────────────────────
# Controls how much RAM each Docker container may use.
# On macOS the VM ceiling is set in Docker Desktop → Settings → Resources.
# Increase if the API crashes on large audits; decrease on low-RAM machines.
API_MEMORY=1g
FRONTEND_MEMORY=512m
